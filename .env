# Default environment variables (shared baseline, committed to git)
# Override these in .env.local (local dev) or .env.prod (production build)

VITE_BFF_API_URL=http://localhost:3000/bff
VITE_WS_URL=ws://localhost:3000
VITE_GOOGLE_MAPS_API_KEY=

# Feature flags — set to 'true' to enable, anything else disables
VITE_FEATURE_MAPS=false
VITE_FEATURE_DIRECTIONS=false
