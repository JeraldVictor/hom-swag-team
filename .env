# Default environment variables (shared baseline, committed to git)
# Override these in .env.local (local dev) or .env.prod (production build)

# VITE_BFF_API_URL — full URL used by the production build (CapacitorHttp native HTTP)
VITE_BFF_API_URL=http://localhost:3000/bff/field
# VITE_BFF_BASE_URL — origin only, used by the Vite dev server proxy target
# Change this to http://<your-machine-ip>:3000 if running the BFF on a different host
VITE_BFF_BASE_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000
VITE_MEDIA_BASE_URL=http://localhost:3000
VITE_GOOGLE_MAPS_API_KEY=

# Feature flags — set to 'true' to enable, anything else disables
VITE_FEATURE_MAPS=false
VITE_FEATURE_DIRECTIONS=false
