{
  "name": "homswag-partner",
  "private": true,
  "version": "1.0.24",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build --mode prod",
    "build:dev": "vue-tsc && vite build",
    "preview": "vite preview",
    "test:e2e": "cypress run",
    "test:unit": "vitest",
    "format": "biome format .",
    "format:write": "biome format . --write",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "type-check": "vue-tsc --noEmit",
    "release:version": "sh ./scripts/update-release-version.sh",
    "precommit:verify": "sh ./scripts/precommit-verify.sh",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm precommit:verify"
  },
  "dependencies": {
    "@aejkatappaja/phantom-ui": "^0.10.1",
    "@capacitor-community/camera-preview": "^8.0.1",
    "@capacitor-community/native-audio": "^8.0.0",
    "@capacitor-firebase/messaging": "^8.2.0",
    "@capacitor/android": "^8.3.3",
    "@capacitor/app": "8.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "8.3.1",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/keyboard": "8.0.3",
    "@capacitor/local-notifications": "^8.1.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/status-bar": "8.0.2",
    "@capawesome/capacitor-app-update": "^8.0.3",
    "@dotenvx/dotenvx": "^1.65.0",
    "@iconify-json/lucide": "^1.2.106",
    "@iconify/vue": "^5.0.1",
    "@ionic/vue": "^8.8.6",
    "@ionic/vue-router": "^8.8.6",
    "axios": "^1.16.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "firebase": "^12.13.0",
    "pinia": "^3.0.4",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "8.3.1",
    "@types/google.maps": "3.58.1",
    "@types/node": "^25.7.0",
    "@vitejs/plugin-legacy": "^5.4.3",
    "@vitejs/plugin-vue": "^4.6.2",
    "@vue/test-utils": "^2.4.10",
    "@vue/typescript-plugin": "^3.2.8",
    "cypress": "^13.17.0",
    "jsdom": "^22.1.0",
    "simple-git-hooks": "^2.13.1",
    "terser": "^5.47.1",
    "typescript": "~5.9.3",
    "vite": "^5.4.21",
    "vitest": "^0.34.6",
    "vue-tsc": "^2.2.12"
  },
  "description": "HomSwag Partner mobile app"
}
